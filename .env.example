# --- Required -----------------------------------------------------------------

# From @BotFather.
TELEGRAM_BOT_TOKEN=123456:ABC...

# Comma-separated Telegram user IDs (get yours from @userinfobot). Anyone not
# listed is ignored. Everyone listed can approve tool calls — i.e. run commands
# on this machine. The broker refuses to start if this is empty.
TELEGRAM_ALLOWED_USERS=123456789

# Required for the topic-per-session workflow: the forum-enabled group where /new
# opens one topic per session. Omit it only for the degraded mode — a DM with the
# bot, one session for the whole chat.
#
# To find the id: start the broker and send /help in the group. The log line
# `[telegram] from <you> chat=-100... topic=...` carries it.
TELEGRAM_GROUP_ID=-1001234567890

# --- Optional -----------------------------------------------------------------

# Directory a session starts in when /new is given no path.
# Default: your home directory.
BROKER_DEFAULT_CWD=/storage/Work

# Where the conversation -> session-id registry is written.
# Default: ~/.claude-telegram-broker.json
BROKER_STATE_FILE=/home/you/.claude-telegram-broker.json

# Model for spawned sessions. Default: whatever the Agent SDK picks.
BROKER_MODEL=claude-opus-4-8

# Baseline behaviour for tools NOT listed in BROKER_ASK_TOOLS:
#   default            standard rules; unmatched tools run without a prompt
#   acceptEdits        auto-accept file edits
#   plan               explore only, no edits
#   bypassPermissions  skip all checks (BROKER_ASK_TOOLS still prompts)
# Default: default
BROKER_PERMISSION_MODE=default

# Tools that ALWAYS require an Allow/Deny confirmation in Telegram. This is what
# actually enforces the gate — read the Security section before shortening it.
# Default: Bash,Write,Edit,NotebookEdit
BROKER_ASK_TOOLS=Bash,Write,Edit,NotebookEdit
