{
  "name": "claude-telegram-broker",
  "version": "0.5.0",
  "description": "Drive Claude Code sessions from Telegram: create, list, fork, watch, and approve tool calls from your phone.",
  "scripts": {
    "configure": "tsx scripts/setup.ts",
    "start": "tsx --env-file-if-exists=.env src/index.ts",
    "print-hooks": "tsx scripts/mirror/print-hooks.ts",
    "smoke": "tsx --env-file-if-exists=.env src/smoke.ts",
    "smoke:fork": "tsx --env-file-if-exists=.env src/smoke-fork.ts",
    "smoke:watch": "tsx --env-file-if-exists=.env src/smoke-watch.ts",
    "test": "node --import tsx --test --test-concurrency=1 test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.209",
    "grammy": "^1.44.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.7.1",
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.4"
    }
  }
}
